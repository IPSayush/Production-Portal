# ─── Database ───
# MongoDB connection string. Use MongoDB Atlas for production.
MONGO_URI=mongodb://127.0.0.1:27017/production-portal

# ─── Authentication ───
# IMPORTANT: Generate a strong random secret for production!
# Run this in terminal: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-strong-random-secret

# ─── Server ───
PORT=5000

# ─── CORS ───
# Set this to your deployed frontend URL in production (e.g., https://your-app.vercel.app)
# FRONTEND_URL=https://your-frontend.vercel.app

# ─── Seed Users ───
# Set to 'true' to seed default users on startup. Disable in production after initial setup.
SEED_ENABLED=true
# Default seed user passwords (change these!)
SEED_MANAGER_PASSWORD=change-me-strong-password
SEED_VIEWER1_PASSWORD=change-me-strong-password
SEED_VIEWER2_PASSWORD=change-me-strong-password
